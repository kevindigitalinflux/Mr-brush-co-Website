# ── Mr Brush & Co — Environment Variables ────────────────────────────────────
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
#
# Vite requirement: all variables exposed to client-side code MUST be prefixed
# with VITE_. They are inlined into the browser bundle at build time.
# Only the anon key should ever have the VITE_ prefix — it is a public key.

# Supabase project URL (safe to be public — identifies your project)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key (safe to be public — RLS is your security layer)
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Cloudflare Worker URL for quote form submissions (replaces direct Supabase calls)
VITE_QUOTE_PROXY_URL=https://mr-brush-quote-proxy.your-subdomain.workers.dev

# ── Server-side only (do NOT prefix with VITE_) ───────────────────────────────
# These are only needed if you add Edge Functions or a backend.
# NEVER add VITE_ prefix to these — they must never reach the browser bundle.

# Supabase service role key (full DB access — server-side only, never expose to client)
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Generic API secret for signing internal requests (server-side only)
# API_SECRET_KEY=your_api_secret_key_here
